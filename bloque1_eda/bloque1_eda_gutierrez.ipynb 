        "# ============================================\n",
        "# CELDA 2: Cargar dataset en PySpark\n",
        "# ============================================\n",
        "\n",
        "# Definir esquema basado en las variables del SIPSA\n",
        "# Variables: año, mes, código departamento, nombre departamento,\n",
        "# código municipio, nombre municipio, nombre producto, variedad,\n",
        "# unidad empaque, equivalencia kg, precio promedio\n",
        "\n",
        "schema = StructType([\n",
        "    StructField(\"anio\", IntegerType(), True),\n",
        "    StructField(\"mes\", IntegerType(), True),\n",
        "    StructField(\"cod_depto\", StringType(), True),\n",
        "    StructField(\"nom_depto\", StringType(), True),\n",
        "    StructField(\"cod_mpio\", StringType(), True),\n",
        "    StructField(\"nom_mpio\", StringType(), True),\n",
        "    StructField(\"grupo\", StringType(), True),        # Verduras, frutas, tubérculos, etc.\n",
        "    StructField(\"producto\", StringType(), True),\n",
        "    StructField(\"variedad\", StringType(), True),\n",
        "    StructField(\"unidad_empaque\", StringType(), True),\n",
        "    StructField(\"equiv_kg\", DoubleType(), True),      # Equivalencia en kilogramos\n",
        "    StructField(\"precio_promedio\", DoubleType(), True) # Precio promedio mayorista\n",
        "])\n",
        "\n",
        "# Cargar datos\n",
        "df_sipsa = spark.read.csv(ruta_dataset, schema=schema, header=True, sep=\";\")\n",
        "\n",
        "# Información básica\n",
        "print(\"=\" * 60)\n",
        "print(\"INFORMACIÓN DEL DATASET SIPSA\")\n",
