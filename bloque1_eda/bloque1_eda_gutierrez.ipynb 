        "print(f\"Total de registros: {df_sipsa.count():,}\")\n",
        "print(f\"Total de columnas: {len(df_sipsa.columns)}\")\n",
        "print(\"\\nEsquema:\")\n",
        "df_sipsa.printSchema()\n",
        "print(\"\\nPrimeras 10 filas:\")\n",
        "df_sipsa.show(10, truncate=False)"
      ],
